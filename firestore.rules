rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "jespere20000@gmail.com" ||
         get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin');
    }

    function isValidProfile(data) {
      return data.keys().hasAll([
        'id', 'email', 'full_name', 'score_afiya', 'tier',
        'status', 'deposit_coefficient', 'retention_coefficient',
        'kyc_status', 'last_activity_at', 'created_at'
      ]) &&
      data.id is string && data.id.size() > 0 &&
      data.score_afiya is number && data.score_afiya >= 0 && data.score_afiya <= 100 &&
      data.tier in ['BRONZE', 'SILVER', 'GOLD', 'PLATINUM'] &&
      data.status in ['ACTIVE', 'RESTRICTED', 'BANNED', 'PENDING_REVIEW'] &&
      data.deposit_coefficient is number &&
      data.retention_coefficient is number &&
      data.kyc_status in ['APPROVED', 'PENDING', 'REJECTED'];
    }

    function isValidWallet(data) {
      return data.keys().hasAll([
        'id', 'owner_id', 'wallet_type', 'balance', 'currency', 'updated_at'
      ]) &&
      (data.owner_id is string || data.owner_id == null) &&
      data.balance is number && data.balance >= 0 &&
      data.currency == 'XOF' &&
      data.wallet_type in [
        'USER_MAIN', 'USER_CERCLES', 'USER_CAPITAL',
        'ESCROW_CONSTITUTION', 'CONTRIBUTION_POOL',
        'GROUP_MINI_FUND', 'GLOBAL_FUND'
      ];
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['id', 'name', 'admin_id', 'contribution_amount', 'currency', 'frequency', 'target_members', 'created_at']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.contribution_amount is number && data.contribution_amount > 0 &&
             data.frequency in ['WEEKLY', 'MONTHLY', 'QUARTERLY'];
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['id', 'cycle_id', 'member_id', 'amount', 'status']) &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['PENDING', 'SUCCESS', 'FAILED'];
    }

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidProfile(request.resource.data) &&
                    request.resource.data.score_afiya == 50 &&
                    request.resource.data.tier == "BRONZE";
      allow update: if isOwner(userId) || isAdmin();
    }

    match /wallets/{walletId} {
      // Lecture : propriétaire du wallet OU membre du groupe concerné OU admin
      allow read: if isAuthenticated() && (
        resource.data.owner_id == request.auth.uid ||
        resource.data.wallet_type == 'GLOBAL_FUND' ||
        isAdmin() ||
        (resource.data.group_id != null &&
         exists(/databases/$(database)/documents/tontine_members/$(resource.data.group_id + '_' + request.auth.uid)))
      );
      allow create: if isAuthenticated() && isValidWallet(request.resource.data) &&
        (request.resource.data.owner_id == request.auth.uid ||
         request.resource.data.owner_id == null ||
         isAdmin());
      allow update: if isAuthenticated() && (
        resource.data.owner_id == request.auth.uid ||
        resource.data.owner_id == null ||
        resource.data.wallet_type == 'GLOBAL_FUND' ||
        isAdmin()
      );
    }

    match /tontine_groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        isValidGroup(request.resource.data) &&
        request.resource.data.admin_id == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.admin_id == request.auth.uid ||
        isAdmin() ||
        (
          resource.data.status in ['FORMING', 'WAITING_VOTE', 'ACTIVE'] &&
          exists(/databases/$(database)/documents/tontine_members/$(groupId + '_' + request.auth.uid))
        )
      );
      allow delete: if isAdmin();
    }

    match /tontine_members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        isAdmin() ||
        // Admin du groupe peut mettre à jour les membres
        get(/databases/$(database)/documents/tontine_groups/$(resource.data.group_id)).data.admin_id == request.auth.uid ||
        // Système peut mettre à jour (status, draw_position, etc.)
        get(/databases/$(database)/documents/tontine_groups/$(resource.data.group_id)).data.status in ['FORMING', 'WAITING_VOTE', 'ACTIVE']
      );
      allow delete: if isAdmin();
    }

    match /cycles/{cycleId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        // Membres du groupe peuvent lire les cycles
        exists(/databases/$(database)/documents/tontine_members/$(resource.data.group_id + '_' + request.auth.uid))
      );
      allow create, update: if isAuthenticated() && (
        isAdmin() ||
        get(/databases/$(database)/documents/tontine_groups/$(request.resource.data.group_id)).data.admin_id == request.auth.uid ||
        get(/databases/$(database)/documents/tontine_groups/$(request.resource.data.group_id)).data.status in ['ACTIVE']
      );
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        resource.data.user_id == null ||
        isAdmin() ||
        (resource.data.group_id != null &&
         exists(/databases/$(database)/documents/tontine_members/$(resource.data.group_id + '_' + request.auth.uid)))
      );
      allow create: if isAuthenticated() && (
        request.resource.data.user_id == request.auth.uid ||
        request.resource.data.user_id == null ||
        isAdmin()
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        isAdmin() ||
        exists(/databases/$(database)/documents/tontine_members/$(resource.data.group_id + '_' + request.auth.uid))
      );
      allow create: if isAuthenticated() && (
        request.resource.data.user_id == request.auth.uid ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        isAdmin() ||
        // Système peut marquer un payment SUCCESS via retenue
        resource.data.group_id != null &&
        exists(/databases/$(database)/documents/tontine_members/$(resource.data.group_id + '_' + request.auth.uid))
      );
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /events/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
